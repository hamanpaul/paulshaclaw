# copilot-local-vllm — GitHub Copilot CLI BYOK (Bring-Your-Own-Key) env.
#
# Copy to ~/.config/paulshaclaw/copilot-local-vllm.env (chmod 600) and fill in.
# scripts/copilot-local-vllm sources this, exports every var, then execs the
# real `copilot`, pointing the CLI at a self-hosted OpenAI-compatible vLLM.
#
# This template is committed; your real env with the key lives OUTSIDE the repo
# (~/.config/paulshaclaw/ or ~/.copilot/) and is never tracked. .gitignore also
# excludes .env and .env.* as a backstop. The host below is RFC 5737
# documentation space — replace it with your own vLLM endpoint.

COPILOT_PROVIDER_BASE_URL=http://192.0.2.10:8001/v1
COPILOT_PROVIDER_TYPE=openai
COPILOT_PROVIDER_API_KEY=REPLACE_WITH_YOUR_VLLM_KEY
COPILOT_MODEL=gemma4-26b-a4b-nvfp4
COPILOT_PROVIDER_MAX_PROMPT_TOKENS=258048
COPILOT_PROVIDER_MAX_OUTPUT_TOKENS=4096
