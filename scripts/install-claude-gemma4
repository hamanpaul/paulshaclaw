#!/usr/bin/env bash
#
# Install claude-gemma4 + its proxy by symlinking them from this repo into a
# bin directory, so the running entrypoint always tracks the repo. This avoids
# the "repo fixed but ~/.local/bin copy is stale" drift.
#
# Usage:
#   scripts/install-claude-gemma4              # symlink into ~/.local/bin
#   PSC_CLAUDE_GEMMA4_BIN_DIR=/path scripts/install-claude-gemma4
#   scripts/install-claude-gemma4 --restart    # also bounce the running proxy
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
BIN_DIR="${PSC_CLAUDE_GEMMA4_BIN_DIR:-$HOME/.local/bin}"
RESTART_PROXY=0

for arg in "$@"; do
  case "$arg" in
    --restart) RESTART_PROXY=1 ;;
    *) echo "unknown argument: $arg" >&2; exit 2 ;;
  esac
done

LAUNCHER_SRC="$SCRIPT_DIR/claude-gemma4"
PROXY_SRC="$SCRIPT_DIR/claude-gemma4-proxy"

for src in "$LAUNCHER_SRC" "$PROXY_SRC"; do
  if [ ! -f "$src" ]; then
    echo "missing source script: $src" >&2
    exit 1
  fi
done

mkdir -p "$BIN_DIR"

link_one() {
  src="$1"
  dest="$2"
  if [ -L "$dest" ] && [ "$(readlink -f "$dest")" = "$(readlink -f "$src")" ]; then
    echo "unchanged: $dest -> $src"
    return
  fi
  rm -f "$dest"
  ln -s "$src" "$dest"
  echo "linked:    $dest -> $src"
}

link_one "$LAUNCHER_SRC" "$BIN_DIR/claude-gemma4"
link_one "$PROXY_SRC" "$BIN_DIR/claude-gemma4-proxy"

if [ "$RESTART_PROXY" = "1" ] && command -v ss >/dev/null 2>&1; then
  pid="$(ss -ltnp 2>/dev/null | grep ':18080' | grep -oP 'pid=\K[0-9]+' | head -1 || true)"
  if [ -n "${pid:-}" ]; then
    kill "$pid" 2>/dev/null || true
    echo "stopped running proxy (pid=$pid); next launch starts the updated one"
  fi
fi

case ":$PATH:" in
  *":$BIN_DIR:"*) ;;
  *) echo "note: $BIN_DIR is not on PATH; add it to run 'claude-gemma4' directly" ;;
esac

echo "done."
