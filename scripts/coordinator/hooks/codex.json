{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "PSC_RELAY_EVENT=session_start ${PSC_REPO_ROOT}/scripts/coordinator/psc-relay-hook.sh",
            "type": "command",
            "managedBy": "psc-coordinator-relay"
          }
        ],
        "matcher": "startup|clear|compact"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "PSC_RELAY_EVENT=stop ${PSC_REPO_ROOT}/scripts/coordinator/psc-relay-hook.sh",
            "type": "command",
            "managedBy": "psc-coordinator-relay"
          }
        ],
        "matcher": ".*"
      }
    ]
  }
}
