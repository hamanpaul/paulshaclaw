{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PSC_RELAY_EVENT=session_start scripts/coordinator/psc-relay-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PSC_RELAY_EVENT=stop scripts/coordinator/psc-relay-hook.sh"
          }
        ]
      }
    ]
  }
}
